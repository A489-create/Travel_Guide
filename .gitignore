# ============================================================================
# 根级 .gitignore - 适用于 FastAPI + Vue 全栈项目
# 各子目录(FastAPIDemo/, frontend/)下保留各自的 .gitignore 作为补充
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.coverage
.coverage.*
dist/
build/

# 虚拟环境
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Node.js / 前端
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# 环境变量与密钥(切勿提交)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env.local
*.pem
*.key

# ---------------------------------------------------------------------------
# 数据库文件
# ---------------------------------------------------------------------------
*.db
*.sqlite3
*.sqlite

# ---------------------------------------------------------------------------
# IDE / 编辑器
# ---------------------------------------------------------------------------
.idea/
.trae/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# 操作系统
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# 临时测试文件(根目录下的临时截图与测试脚本)
# ---------------------------------------------------------------------------
_shot_*.png
_test_frontend.py
